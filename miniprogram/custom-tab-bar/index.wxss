.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  box-shadow: 0 -4rpx 20rpx rgba(15, 23, 42, 0.06);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 10rpx;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-bar-text {
  margin-top: 4rpx;
  font-size: 20rpx;
  line-height: 1.2;
}

.tab-bar-item--active .tab-bar-text {
  font-weight: 600;
}
