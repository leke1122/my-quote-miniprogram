.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1rpx solid #e2e8f0;
  box-shadow: 0 -6rpx 24rpx rgba(15, 23, 42, 0.08);
  z-index: 9999;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding-top: 6rpx;
}

.tab-icon-wrap {
  width: 72rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.tab-bar-item--active .tab-icon-wrap {
  background: #f1f5f9;
}

.tab-bar-icon {
  width: 52rpx;
  height: 52rpx;
}

.tab-bar-text {
  font-size: 26rpx;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
}

.tab-bar-item--active .tab-bar-text {
  font-weight: 700;
}
