.home-page {
  min-height: 100vh;
  background: #f1f5f9;
  padding-bottom: calc(130rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.home-header {
  padding: 32rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #131b2e 0%, #1e293b 100%);
  color: #fff;
}

.home-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.home-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.search-bar {
  margin-top: 28rpx;
}

.search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.search-placeholder {
  color: rgba(255, 255, 255, 0.55);
}

.home-body {
  padding-top: 16rpx;
}

.hint {
  display: block;
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.module-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.module-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.module-icon-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.module-body {
  flex: 1;
  min-width: 0;
}

.module-title-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.module-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.module-tag {
  font-size: 20rpx;
  font-weight: 700;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.module-tag--blue {
  color: #2563eb;
  background: #dbeafe;
}

.module-tag--violet {
  color: #7c3aed;
  background: #ede9fe;
}

.module-tag--green {
  color: #059669;
  background: #d1fae5;
}

.module-tag--amber {
  color: #b45309;
  background: #fef3c7;
}

.module-tag--rose {
  color: #e11d48;
  background: #ffe4e6;
}

.module-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.module-arrow {
  flex-shrink: 0;
  font-size: 40rpx;
  color: #cbd5e1;
  font-weight: 300;
}
