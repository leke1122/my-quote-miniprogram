<view class="container form-page">
  <view class="form-card">
    <text class="form-label required">商品编号</text>
    <input class="form-input" value="{{form.code}}" data-field="code" bindinput="onFieldInput" />
    <text class="form-label required">商品名称</text>
    <input class="form-input" value="{{form.name}}" data-field="name" bindinput="onFieldInput" placeholder="必填" />
    <text class="form-label">型号</text>
    <input class="form-input" value="{{form.model}}" data-field="model" bindinput="onFieldInput" />
    <text class="form-label">规格</text>
    <input class="form-input" value="{{form.spec}}" data-field="spec" bindinput="onFieldInput" />
    <text class="form-label">单位</text>
    <input class="form-input" value="{{form.unit}}" data-field="unit" bindinput="onFieldInput" />
    <text class="form-label">单价（元）</text>
    <input class="form-input" type="digit" value="{{priceStr}}" bindinput="onPriceInput" />
  </view>
</view>
<view class="form-footer">
  <button wx:if="{{isEdit}}" class="btn-danger" disabled="{{saving}}" bindtap="onDelete">删除</button>
  <button class="btn-secondary" disabled="{{saving}}" bindtap="onCancel">取消</button>
  <button class="btn-primary" loading="{{saving}}" disabled="{{saving}}" bindtap="onSave">保存</button>
</view>
