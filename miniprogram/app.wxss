page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB",
    "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #1e293b;
  background-color: #f1f5f9;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx 48rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.btn-primary {
  background: #131b2e;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}
