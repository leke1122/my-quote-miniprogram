page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB",
    "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #1e293b;
  background-color: #f1f5f9;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx 48rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.card-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.5;
}

.btn-primary {
  background: #131b2e;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.muted {
  color: #64748b;
  font-size: 24rpx;
}

.list-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.btn-compact {
  width: auto !important;
  margin: 0 !important;
  padding: 0 28rpx !important;
  height: 64rpx !important;
  line-height: 64rpx !important;
  font-size: 26rpx !important;
}

.list-header {
  margin-bottom: 16rpx;
}

.form-page {
  padding-bottom: 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
  margin-top: 20rpx;
}

.form-card .form-label:first-child {
  margin-top: 0;
}

.form-label.required::after {
  content: " *";
  color: #dc2626;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  font-size: 28rpx;
  color: #0f172a;
  box-sizing: border-box;
}

.form-row-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 24rpx rgba(15, 23, 42, 0.08);
  display: flex;
  gap: 16rpx;
  z-index: 10;
}

.form-footer button {
  flex: 1;
  margin: 0;
}

.btn-secondary {
  background: #e2e8f0 !important;
  color: #334155 !important;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background: #fef2f2 !important;
  color: #dc2626 !important;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-danger::after {
  border: none;
}

.list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.list-row-main {
  flex: 1;
  min-width: 0;
}

.list-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
  line-height: 1.4;
}

.list-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
}

.list-meta {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: #3d5a80;
  max-width: 200rpx;
  text-align: right;
}

.empty-box {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.06);
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.empty-desc {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.6;
}

.empty-box .btn-primary {
  margin-top: 32rpx;
}
